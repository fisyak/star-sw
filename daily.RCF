foreach p (muon+ muon- pion+ pion- electron- electron+ kaon+ kaon- proton+ proton- deuteron triton He3 alpha)
	if (! -d ${p}) mkdir ${p}
        cd ${p}
	ln -s ../${p}*200.root .
	ln -s ~/macros/.al* .
        if (! -r AdcSparse8.root) root.exe -q -b AdcTpcT.C >& AdcTpcT8.log &
	if (! -r SparseT0Flagged.root.T0.root) root.exe -q -b T0offset.C >& T0offset.log &
        if (! -r ${p}.root) hadd -T ${p}.root ${p}*[0-9].root >& hadd.log &
        cd -
end
################################################################################
foreach p (muon+ muon- pion+ pion- electron- electron+ kaon+ kaon- proton+ proton- deuteron triton He3 alpha)
	if (! -d ${p}) mkdir ${p}
        cd ${p}
        if (! -r AdcSparse8.root) root.exe -q -b AdcTpcT.C >& AdcTpcT8.log &
	if (! -r SparseT0Flagged.root.T0.root) root.exe -q -b T0offset.C >& T0offset.log &
        if (! -r ${p}.root) hadd -T ${p}.root ${p}*[0-9].root >& hadd.log &
        cd -
end

foreach f (`grep -l fix */*/hadd.log`)
  set d = `dirname ${f}`
  set p = `basename ${d}`
  cd ${d}
  grep fix hadd.log | awk '{print $12}' | sed -e 's/,//' | sort -u | xargs rm 
  mv ${p}.root ${p}.root1
  hadd -T ${p}.root ${p}*[0-9].root >& hadd.log &
  cd -
end

foreach p (muon+ muon- pion+ pion- electron- electron+ kaon+ kaon- proton+ proton- deuteron triton He3 alpha)
        cd ${p}
   	root.exe -q -b lBichsel.C AdcSparse8*.root 'dEdxFit.C+("Sparse","GP")' >& dEdxFit.log &
        cd -
end

foreach f (`ls -1d  */*/AdcSparse8.root`)
  set d = `dirname ${f}`
  cd ${d}
  root.exe -q -b lBichsel.C AdcSparse8*.root 'dEdxFit.C+("Sparse","GP")' >& dEdxFit.log &
  cd -
end


