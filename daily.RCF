#sigma(@61 npts) =  6.38% for E- AuAu_2023_2
#mu =  2.90% for E- AuAu_2023_1
#mu =  0.42% for E- AuAu_2023_2

foreach d (`ls -1d /gpfs01/star/data100/TPC/daq/2023/*/*`)
  set dir = `dirname ${d}`
  set b = `echo ${d} | sed -e 's#/gpfs01/star/data100/TPC/daq/2023/##'`
  echo "${b}"
  if (-r ${b}) continue;
  set c = `dirname ${b}`
  set a = `basename ${b}`
  if (-r ${c}) then 
    cd ${c}
    ln -s ${d} .
    echo "${d} => ${b} => ${c} => ${a}"
    cd -
  else 
    ln -s ${dir} . 
    echo "${d} => ${dir} => ${c} "
  endif 
end

