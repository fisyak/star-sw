04/03/2026
[l409] /hlt/cephfs/reco $ find EandB/ -name "Cosmics.root" -o -name "MdYZ.root" | tee root.list
foreach f (`cat root.list`)
   set b = `basename ${f}`
   set d = /direct/gpfs01/star/data100/TPC/reco/`dirname ${f}`;
   if (-r ${d}/${b}) continue;
   echo "${f} => ${d}"
   if (! -d ${d}) mkdir -p ${d}
   cp -p  ${f} ${d}/
end

   
EandB/2025/RF/Cosmic/080/Cosmics.root => /direct/gpfs01/star/data100/TPC/reco/EandB/2025/RF/Cosmic/080

foreach p (electron kaon proton deuteron triton muon)
  hadd.pl option=-T files='../'${p}'*200.root'
end
