04/02/21  
foreach dd (`ls -1d */*P21ib/dEdx`)
  set d = `dirname ${dd}`; echo "${d}"
  set b = `basename ${d}`; echo "${d} => ${b}"
  cd ${dd}
  if (! -r ../${b}.root ) hadd ../${b}.root All*.root >& hadd.log &
  cd -
end

foreach dd (`ls -1d */*P21ib/dEdx`)
  set d = `dirname ${dd}`; echo "${d}"
  set b = `basename ${d}`; echo "${d} => ${b}"
  set rootf =  ../${b}.root
  cd ${dd}
  lb -1d ${rootf}
  if ( -r ${rootf} ) then
	  root.exe ${rootf} brtw.C+ ppbarM2.C+
	  root.exe ${rootf} DrawSignalBg7.C
	  root.exe ${rootf} DrawSignalBg_HL34.C
  endif
  cd -
end

foreach dd (`ls -1d */*P21ib/dEdx`)
	cd ${dd}
	PicoL.pl
        if (! $?) then
           lsf ~/xml/kfpAnalysis.xml
	endif
        cd -
end	
#hadd
foreach dd (`ls -1d */*P21ib/dEdx`)
  set d = `dirname ${dd}`; echo "${d}"
  set b = `basename ${d}`; echo "${d} => ${b}"
  cd ${dd}
  ls -ltr *.root | tail -1 | grep All	
  if ($?) then
    rm All*
    hadd.pl 
    lsf hadd.xml;
  endif
  cd -
end
