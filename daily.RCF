03/26/2026
foreach p (muon+ muon-)
	if (! -d ${p}) mkdir ${p}
        cd ${p}
	ln -s ../${p}*200.root .
	ln -s ~/macros/.al* .
        if (! -r AdcSparse8.root) root.exe -q -b AdcTpcT.C >& AdcTpcT8.log &
	if (! -r SparseT0Flagged.root.T0.root) root.exe -q -b T0offset.C >& T0offset.log &
        if (! -r ${p}.root) hadd -T ${p}.root ${p}*[0-9].root >& hadd.log &
        cd -
end
 root.exe -q -b 'Chain.C+("muon*200.root","TpcT")' | tee Chain.log
 mv `grep missing Chain.log | awk '{print $3}' | sed -e 's/.root/*/' ` Zombie/


