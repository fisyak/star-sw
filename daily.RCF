Copy links fromTpcZCorrectionC.*.C TpcSecRowB

foreach f (`ls -1d TpcZCorrectionC.*.C`)
 set t = `echo ${f} | sed -e 's/TpcZCorrectionC/TpcSecRowB/' -e 's/.C$/.root/'`
 ln -s TpcSecRowB.root ${t}
end

dirc TpcZCorrectionC.* | grep '\->' | awk -F\. '{print "ln -sf TpcSecRowB."$4".root TpcSecRowB."$2".root"}'

foreach f (`ls -1d  ~/work/Histograms/RunXIX_XXI27/TpcSecRowB.*.root`)
  set b = `basename ${f}`
  ls -l ${b}
  if ( ! $?) echo "rm ${b}"
  echo "cp -p ${f} ${b}"
end

foreach f (`ls -1d  ~/work/Histograms/RunXIX_XXI27/TpcSecRowB.*.root`)
  set b = `basename ${f}`
  ls ${b}
  if (! $?) rm ${b}
  cp -p ${f} ${b}
end

foreach f (`ls -1d job*.xml`)
 set d = `echo ${f} |sed -e 's/jobs.//' -e 's/.xml//'`
 mkdir ${d}
 cd ${d}
 lsf ../${f}
 cd -
end
