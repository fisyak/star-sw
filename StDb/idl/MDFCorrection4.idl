struct MDFCorrection4 {
  octet   idx; // row index
  octet   nrows; // total no. of real rows in the table; For Db interface (where nrows = 50)
  octet   PolyType;  // type = 0 kMonomials, type = 1 kChebyshev, type = 2 kLegendre + 10 for alternative conversion type
  octet   NVariables;// <= 4 for now. if NVariables < 0 don't estrapolate out side of [Xmin, Xmax] ,i.e. set  0 otherwise use value at limit
  octet   NCoefficients;// <= 50
  octet   Power[150];    //  p_ijk = Power[i * NVariables + j];
  double  DMean; // 
  double  XMin[4];
  double  XMax[4];
  double  Coefficients[50]; 
  double  CoefficientsRMS[50]; 
};
